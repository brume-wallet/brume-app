# Supabase — two different URLs (do not copy the same host and only change the port).
# Put secrets in `.env.local` (git-ignored); this file is the template only.
#
# DATABASE_URL — Transaction pooler (Next.js app at runtime)
#   User:     postgres.[PROJECT_REF]
#   Host:     aws-0-REGION.pooler.supabase.com  (or aws-1-…)
#   Port:     6543
#   Query:    ?pgbouncer=true
#   Example:
#   postgresql://postgres.[PROJECT_REF]:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL — Direct Postgres (pnpm db push / migrations). NOT the pooler hostname.
#   User:     postgres   ← plain "postgres", not postgres.[PROJECT_REF]
#   Host:     db.[PROJECT_REF].supabase.co
#   Port:     5432
#   Example:
#   postgresql://postgres:YOUR_PASSWORD@db.[PROJECT_REF].supabase.co:5432/postgres
#
# Copy these from Supabase: Project Settings → Database → Connection string.
# Use the "Transaction pooler" URI for DATABASE_URL and "Direct connection" for DIRECT_URL.
#
# Rules:
# - There must be exactly one "@" between PASSWORD and HOST (no @ inside the password unless URL-encoded as %40).
# - Hash in password: use %23 (e.g. pass `a#b` → `a%23b`). @ : / ? % also need encoding or the URI breaks.
#
DATABASE_URL=
DIRECT_URL=

# Helius — DAS (getAssetsByOwner) + parsed transaction history (optional fallback uses RPC)
HELIUS_API_KEY=

# Optional: default RPC when extension does not pass rpcUrl (public endpoints are rate-limited)
# DEVNET_RPC_URL=https://api.devnet.solana.com
# MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
