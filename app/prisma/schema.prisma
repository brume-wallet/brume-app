generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TokenMetadata {
  id          String   @id @default(cuid())
  network     String
  mint        String
  name        String
  symbol      String
  logoUri     String?
  metadataUri String?
  decimals    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([network, mint])
  @@index([network, mint])
}
